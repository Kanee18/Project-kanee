# Copy this file to backend/.env and fill in the key for your llm.provider.
# .env is gitignored — never commit real keys.

# provider: google (Google AI Studio) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# provider: anthropic
ANTHROPIC_API_KEY=

# provider: openai
OPENAI_API_KEY=
